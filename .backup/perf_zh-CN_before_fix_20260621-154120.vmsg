counter.cpu.capacity.entitlement.summary                          = "CPU resources 分配 ESXi 调度程序 to the 虚拟 machines and 资源 pools"
counter.cpu.capacity.entitlement.VM.label                         = "CPU 容量 权利"
counter.cpu.capacity.entitlement.VM.summary                       = "CPU resources 分配 ESXi 调度程序 to the 虚拟 machines and 资源 pools"
counter.cpu.capacity.provisioned.label="CPU 容量 已置备"
counter.cpu.capacity.provisioned.summary                          = "容量 in MHz of the 物理 CPU 内核数"
counter.cpu.capacity.provisioned.DPU.label="CPU 容量 已置备"
counter.cpu.capacity.provisioned.DPU.summary                      = "标称容量 in MHz of the 数据处理单元"
counter.cpu.capacity.provisioned.HOST.label="CPU 容量 已置备"
counter.cpu.capacity.provisioned.HOST.summary                     = "标称容量 in MHz of the 物理 CPU 内核数 without taking into account any possible 频率 提升 of 超线程 已启用"
counter.cpu.capacity.usage.label="CPU 容量 使用率"
counter.cpu.capacity.usage.summary                                = "CPU 使用率 百分比 during the 间隔"
counter.cpu.capacity.usage.DPU.label="CPU 容量 使用率"
counter.cpu.capacity.usage.DPU.summary                            = "CPU 使用率 in MHz of the 整个 数据处理单元 during the last 测量间隔. Can be higher than the reported 已置备 容量 due to 已启用 超线程 and/or 处理器 正在运行 into 频率 提升 mode"
counter.cpu.capacity.usage.HOST.label="CPU 容量 使用率"
counter.cpu.capacity.usage.HOST.summary                           = "CPU 使用率 in MHz of the 整个 主机 during the last 测量间隔. Can be higher than the reported 已置备 容量 due to 已启用 超线程 and/or 处理器 正在运行 into 频率 提升 mode"
counter.cpu.capacity.usage.VM.label="CPU 容量 使用率"
counter.cpu.capacity.usage.VM.summary                             = "CPU 使用率 in MHz for this 虚拟机 during the last 测量间隔, 基于 the 虚拟 CPUs 正在运行. Can be higher than the reported 已置备 容量 due to 已启用 超线程 and/or 处理器 正在运行 into 频率 提升 mode"
counter.cpu.coreUtilization.label                                 = "内核 利用率"
counter.cpu.coreUtilization.summary                               = "CPU 利用率 of the corresponding 内核 (if 超线程 is 已启用) 百分比 during the 间隔 (A 内核 is 已利用 if 任一 or 两者 of its 逻辑 CPUs are 已利用)"
counter.cpu.corecount.contention.label                            = "CPU 内核 计数 争用"
counter.cpu.corecount.contention.summary                          = "时间 the VM vCPU is 就绪 to run, but is 无法 run due to 协同调度约束"
counter.cpu.corecount.contention.HOST.label                       = "CPU 内核 计数 争用"
counter.cpu.corecount.contention.HOST.summary                     = "Aggregated 时间 of all vCPUs which are 就绪 to run, but is 无法 run due to 协同调度约束, in 百分比"
counter.cpu.corecount.contention.VM.label                         = "CPU 内核 计数 争用"
counter.cpu.corecount.contention.VM.summary                       = "时间 the VM is 就绪 to run, but is 无法 run due to 协同调度约束"
counter.cpu.corecount.contention.VM.VCPU.label                    = "CPU 内核 计数 争用"
counter.cpu.corecount.contention.VM.VCPU.summary                  = "时间 the VM vCPU is 就绪 to run, but is 无法 run due to 协同调度约束"
counter.cpu.corecount.provisioned.label                           = "CPU 内核 计数 已置备"
counter.cpu.corecount.provisioned.summary                         = "The 虚拟 处理器数 已置备 to the 实体"
counter.cpu.corecount.provisioned.DPU.label                       = "CPU 内核 计数 已置备"
counter.cpu.corecount.provisioned.DPU.summary                     = "The 物理 处理器数 存在 on the 数据处理单元"
counter.cpu.corecount.provisioned.HOST.label                      = "CPU 内核 计数 已置备"
counter.cpu.corecount.provisioned.HOST.summary                    = "The 物理 内核数 已置备 to the 实体"
counter.cpu.corecount.provisioned.VM.label                        = "CPU 内核 计数 已置备"
counter.cpu.corecount.provisioned.VM.summary                      = "The 虚拟 处理器数 已置备 to the 实体"
counter.cpu.corecount.usage.label                                 = "CPU 内核 计数 使用率"
counter.cpu.corecount.usage.summary                               = "The 虚拟 处理器数 正在运行 on the 主机"
counter.cpu.corecount.usage.HOST.label                            = "CPU 内核 计数 使用率"
counter.cpu.corecount.usage.HOST.summary                          = "The 虚拟 处理器数 正在运行 on the 主机"
counter.cpu.corecount.usagePct.label                              = "CPU 内核 计数 使用率"
counter.cpu.corecount.usagePct.summary                            = "The 虚拟 处理器数 正在运行 on the 主机, 占……的百分比 the 物理 内核数"
counter.cpu.costop.label="Co-stop"
counter.cpu.costop.summary                                        = "时间 the 虚拟机 is 就绪 to run, but is 无法 run due to 协同调度约束"
counter.cpu.costop.RESPOOL.label="%CSTP"
counter.cpu.costop.RESPOOL.summary                                = "The 百分比 (非规范化 从 0% up to 100xNumWorlds%) of 时间 the worlds of this 资源池 / 调度组 spent in 就绪, 协同取消调度状态. Returned only for SMP VMs"
counter.cpu.cpuentitlement.label="Worst case 分配"
counter.cpu.cpuentitlement.summary                                = "CPU resources 已分配 to the 虚拟机 or 资源池, 基于 the 总计 集群 容量 and the 资源 configuration of the 资源 hierarchy"
counter.cpu.dem和.label="Dem和"
counter.cpu.dem和.summary="The a挂载 of CPU 资源 a 虚拟机 would use if there were no CPU contention or CPU 限制"
counter.cpu.dem和EntitlementRatio.label="需求-to- entitlement  ratio"
counter.cpu.dem和EntitlementRatio.summary="CPU 资源  entitlement  to CPU 需求 ratio (百分比s)"
counter.cpu.entitlement.label="Entitlement"
counter.cpu.entitlement.summary                                   = "CPU resources 分配 ESX 调度程序"
counter.cpu.extra.label="Extra"
counter.cpu.extra.summary                                         = "额外 CPU 时间"
counter.cpu.guaranteed.label="Guaranteed"
counter.cpu.guaranteed.summary                                    = "CPU 时间 that is 已预留 for the 实体"
counter.cpu.idle.label="Idle"
counter.cpu.idle.summary                                          = "总计 时间 that the CPU spent in an 空闲 状态"
counter.cpu.latency.label="Latency"
counter.cpu.latency.summary                                       = "百分比 of 时间 the 虚拟机 is 无法 run because it is 争用对……的访问 the 物理 CPU(s)"
counter.cpu.load.avg15min.label                                   = "CPU 负载 平均 15 mins"
counter.cpu.load.avg15min.summary                                 = "CPU 负载 平均 过去 15 minutes, 已采样 on every 6 seconds"
counter.cpu.load.avg15min.HOST.label                              = "CPU 负载 平均 15 mins"
counter.cpu.load.avg15min.HOST.summary                            = "CPU 负载 平均 过去 15 minutes, 已采样 on every 6 seconds"
counter.cpu.load.avg1min.label                                    = "CPU 负载 平均 1 min"
counter.cpu.load.avg1min.summary                                  = "CPU 负载 平均 过去 1 minute, 已采样 on every 6 seconds"
counter.cpu.load.avg1min.HOST.label                               = "CPU 负载 平均 1 min"
counter.cpu.load.avg1min.HOST.summary                             = "CPU 负载 平均 过去 1 minute, 已采样 on every 6 seconds"
counter.cpu.load.avg5min.label                                    = "CPU 负载 平均 5 mins"
counter.cpu.load.avg5min.summary                                  = "CPU 负载 平均 过去 5 minutes, 已采样 on every 6 seconds"
counter.cpu.load.avg5min.HOST.label                               = "CPU 负载 平均 5 mins"
counter.cpu.load.avg5min.HOST.summary                             = "CPU 负载 平均 过去 5 minutes, 已采样 on every 6 seconds"
counter.cpu.maxlimited.label                                      = "Max 受限"
counter.cpu.maxlimited.summary                                    = "时间 the 虚拟机 is 就绪 to run, but is not run due to 达到上限 its CPU 限制 setting"
counter.cpu.maxlimited.RESPOOL.label="%MLMTD"
counter.cpu.maxlimited.RESPOOL.summary                            = "The 百分比 (非规范化 从 0% up to 100xNumWorlds%) of 时间 the worlds of this 资源池 / 调度组 was 就绪 to run but deliberately wasn't scheduled because they are violate the 'CPU 限制' settings. Note that %MLMTD is 包含于 %RDY"
counter.cpu.overlap.label="Overlap"
counter.cpu.overlap.summary                                       = "时间 the 虚拟机 was interrupted to perform 系统 services on behalf of itself or 其他 虚拟 machines"
counter.cpu.partnerBusyTime.label                                 = "PCPU Partner Busy 时间(%)"
counter.cpu.partnerBusyTime.summary                               = "The 百分比 HT partner 使用率 每 物理 CPU"
counter.cpu.partnerBusyTime.PCPU.label                            = "PCPU Partner Busy 时间(%)"
counter.cpu.partnerBusyTime.PCPU.summary                          = "The 百分比 HT partner 使用率 每 物理 CPU"
counter.cpu.readiness.label="Readiness"
counter.cpu.readiness.summary                                     = "百分比 of 时间 that the 虚拟机 was 就绪, but could not get scheduled to run on the 物理 CPU"
counter.cpu.ready.label="Ready"
counter.cpu.ready.summary                                         = "时间 that the 虚拟机 was 就绪, but could not get scheduled to run on the 物理 CPU during last 测量间隔"
counter.cpu.ready.RESPOOL.label="%RDY"
counter.cpu.ready.RESPOOL.summary                                 = "Accounts the 百分比 (非规范化 从 0% up to 100xNumWorlds%) of 时间 that all of the worlds 从 this 资源 组 / 调度组 are spending in run-队列 就绪 to be run, but 无法 be scheduled"
counter.cpu.reserved.label="Reserved"
counter.cpu.reserved.summary="CPU 已预留"
counter.cpu.reservedCapacity.label="已预留 容量"
counter.cpu.reservedCapacity.summary                              = "总计 CPU 容量 已预留 by 虚拟 machines"
counter.cpu.reservedcapacity.label="已预留 容量"
counter.cpu.reservedcapacity.summary                              = "总计 CPU 容量 已预留 by 虚拟 machines"
counter.cpu.run.label="Run"
counter.cpu.run.summary                                           = "时间 the 虚拟机 is scheduled to run"
counter.cpu.run.RESPOOL.label="%RUN"
counter.cpu.run.RESPOOL.summary                                   = "The 百分比 (非规范化 从 0% up to 100xNumWorlds%) of 总计 scheduled 时间 for the 资源池 / 调度组 to run (%已用 = %RUN + %SYS - %OVRLP)"
counter.cpu.runav1.label                                          = "正在运行 (1 min 平均)"
counter.cpu.runav1.summary                                        = "CPU 正在运行 平均 over 1 minute"
counter.cpu.runav15.label                                         = "正在运行 (15 min 平均)"
counter.cpu.runav15.summary                                       = "CPU 正在运行 平均 over 15 minutes"
counter.cpu.runav5.label                                          = "正在运行 (5 min 平均)"
counter.cpu.runav5.summary                                        = "CPU 正在运行 平均 over 5 minutes"
counter.cpu.swapwait.label                                        = "交换 等待"
counter.cpu.swapwait.summary                                      = "CPU 时间 spent waiting for 交换-in"
counter.cpu.swapwait.RESPOOL.label="%SWPWT"
counter.cpu.swapwait.RESPOOL.summary                              = "The 百分比 (非规范化 从 0% up to 100xNumWorlds%) of 时间 the worlds of this 资源池 / 调度组 are waiting for the ESX VMKernel swapping 内存. The 交换 等待 时间 is 包含于 the %等待 时间"
counter.cpu.system.label="System"
counter.cpu.system.summary                                        = "时间 spent on 系统进程 on each 虚拟 CPU in the 虚拟机"
counter.cpu.totalCapacity.label="总计 容量"
counter.cpu.totalCapacity.summary                                 = "总计 CPU 容量 已预留 by and 可用 for 虚拟 machines"
counter.cpu.totalmhz.label="Total"
counter.cpu.totalmhz.summary                                      = "总计 CPU resources of all hosts in the 集群"
counter.cpu.usage.label="Usage"
counter.cpu.usage.summary                                         = "CPU 使用率 百分比 during the 间隔"
counter.cpu.usage.DPU.label="Usage"
counter.cpu.usage.DPU.summary                                     = "CPU 使用率 on the 数据处理单元 百分比 during the 间隔"
counter.cpu.usage.DPU.PCPU.label="Usage"
counter.cpu.usage.DPU.PCPU.summary                                = "CPU 使用率 of 物理 CPU on the 数据处理单元 百分比 during the 间隔"
counter.cpu.usage.HOST.label="PCPU 已用(%)"
counter.cpu.usage.HOST.summary                                    = "规范化 (0 to 100%) CPU 使用率 跨 all of the 物理 CPUs on the 主机"
counter.cpu.usage.PCPU.label="PCPU 已用(%)"
counter.cpu.usage.PCPU.summary                                    = "The 百分比 CPU 使用率 每 物理 CPU"
counter.cpu.usage.RESPOOL.label="%已用"
counter.cpu.usage.RESPOOL.summary                                 = "CPU 使用率 (in 百分比 非规范化 从 0% up to 100xNumWorlds%) for this 资源池 / 调度组 during last 测量间隔"
counter.cpu.usage.vcpus.label                                     = "VCPU 使用率"
counter.cpu.usage.vcpus.summary                                   = "虚拟 CPU 使用率 百分比 during the 间隔"
counter.cpu.usagemhz.label="使用率 in MHz"
counter.cpu.usagemhz.summary                                      = "CPU 使用率 in 兆赫 during the 间隔"
counter.cpu.used.label="Used"
counter.cpu.used.summary="总计 CPU 使用率"
counter.cpu.utilization.label="Utilization"
counter.cpu.utilization.summary                                   = "CPU 利用率 百分比 during the 间隔 (CPU 使用率 and CPU 利用率 might be different due to 电源 管理 技术 or 超线程)"
counter.cpu.utilization.PCORE.label                               = "内核 UTIL(%)"
counter.cpu.utilization.PCORE.summary                             = "The 百分比 of CPU 周期 每 内核 when at least one of the PCPUs in this 内核 is 未暂停. It's the 反转 of the 内核 空闲, which is the 百分比 of CPU 周期 when all PCPUs in this 内核 are 已暂停. Effectively, equal to cpu.利用率 每 PCPU when 超线程 is not 已用"
counter.cpu.utilization.PCPU.label="PCPU UTIL(%)"
counter.cpu.utilization.PCPU.summary                              = "The 百分比 of 未暂停 CPU 周期 每 物理 CPU"
counter.cpu.wait.label="Wait"
counter.cpu.wait.summary                                          = "总计 CPU 时间 spent in 等待 状态"
counter.cpu.wait.RESPOOL.label="%WAIT"
counter.cpu.wait.RESPOOL.summary                                  = "This is the 总计 等待 时间 (in 百分比 非规范化 从 0% up to 100xNumWorlds%). I.e., the 资源池 / 调度组 is waiting for some VMKernel 资源. This 等待 时间 包含 I/O 等待 时间, 空闲 时间 and among 其他 resources"
