###Alarms email tempalte
### TriggeredAlarm
TriggeredAlarm.Status.gray.label="Unset"
TriggeredAlarm.Status.gray.summary="Does not 更改 the entity 状态"
TriggeredAlarm.Status.green.label="正常"
TriggeredAlarm.Status.green.summary="Indicates normal operation"
TriggeredAlarm.Status.yellow.label="警告"
TriggeredAlarm.Status.yellow.summary="Indicates an 错误"
TriggeredAlarm.Status.red.label="Critical"
TriggeredAlarm.Status.red.summary="Indicates an  严重 错误"
###
###
Email.statefulAlarm.subject="[{newStatus}] 警报 {alarmName} on {targetType} {targetName}"
Email.statefulAlarm.body="This email is to notify you that an 警报 has been 触发 in your vCenter:<br><b>[{newStatus}] 警报 {alarmName} on {targetType} {targetName}<br></b>because <b>{targetType} {triggeringSummary}.</b><br><table><tr><td>警报 名称</td><td>{alarmName}</td></tr><tr><td>描述</td><td>{alarmDescription}</td></tr><tr><td>Target</td><td>{targetType} {targetName}</td></tr><tr><td>状态</td><td>{newStatus} (上一个 状态: {oldStatus})</td></tr><tr><td>Triggered time</td><td>{triggeredTime}</td></tr></table>"
###
###
Email.statefulEventAlarm.subject="[{newStatus}] 警报 {alarmName} on {targetType} {targetName}"
Email.statefulEventAlarm.body="This email is to notify you that an 警报 has been 触发 in your vCenter:<br><b>[{newStatus}] 警报 {alarmName} on {targetType} {targetName}<br></b>because <b>{eventDescription}.</b><br><table><tr><td>警报 名称</td><td>{alarmName}</td></tr><tr><td>描述</td><td>{alarmDescription}</td></tr><tr><td>Target</td><td>{targetType} {targetName}</td></tr><tr><td>状态</td><td>{newStatus} (上一个 状态: {oldStatus})</td></tr><tr><td>Triggered time</td><td>{triggeredTime}</td></tr></table>"
###

###
Email.statelessEventAlarm.subject="警报 {alarmName} on {targetType} {targetName}"
Email.statelessEventAlarm.body="This email is to notify you that an 警报 has been 触发 in your vCenter:<br><b>警报 {alarmName} on {targetType} {targetName}<br></b>because <b>{eventDescription}.</b><br><table><tr><td>警报 名称</td><td>{alarmName}</td></tr><tr><td>描述</td><td>{alarmDescription}</td></tr><tr><td>Target</td><td>{targetType} {targetName}</td></tr><tr><td>Triggered time</td><td>{triggeredTime}</td></tr></table>"
