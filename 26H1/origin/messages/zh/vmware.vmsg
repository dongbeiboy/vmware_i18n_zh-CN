msg.guestos.badname = "客户操作系统「%1$s」不受支持。|0A请在 [虚拟机设置] 的 [%3$s] 选项卡中的 [%2$s] 页面选择客户操作系统。|0A"
msg.guestos.bootcamp = "正在尝试在 %1$s 上首次使用 Boot Camp 分区。|0A首次使用时，Microsoft Windows 检测鼠标和其他虚拟硬件可能需要最多一分钟。|0A|0A在某些系统上，首次启动时可能无法检测到鼠标。要启用鼠标，请关闭虚拟机电源后重新启动。|0A|0A可能会提示重新激活 Windows。建议在重新激活之前安装 %2$s。|0A|0A要安装 %3$s，请等待 Windows 启动完成后，选择 [%4$s] - [%5$s] 并按照指示操作。|0A"
msg.guestos.noname = "配置文件中未指定客户操作系统。|0A请在 [虚拟机设置] 的 [%2$s] 选项卡中的 [%1$s] 页面选择客户操作系统。|0A"
msg.gui.cannotReconnect = "无法连接设备。此虚拟机已将 %1$s 配置为客户端设备。请手动重新连接设备。|0A"
msg.gui.cannotchangedir = "无法将目录更改为 %1$s：%2$s|0A"
msg.gui.noTools = "没有可用的 %1$s 软件包。此客户操作系统不支持 %2$s 软件包。|0A"
