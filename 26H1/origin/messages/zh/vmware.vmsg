msg.busmem.tooLargeEPC = "虚拟机配置的内存容量过大。|0A%1$s 主内存和 %2$s EPC 超出了允许的上限 %3$s|0A"
msg.busmem.tooLargeMem = "虚拟机配置的内存容量过大。|0A%1$s 主内存、%2$s PMEM 和 %3$s EPC 超出了允许的上限 %4$s|%0A"
msg.busmem.tooLargePMEM = "虚拟机配置的内存容量过大。|0A%1$s 主内存和 %2$s PMEM 超出了允许的上限 %3$s|0A"
msg.cdrom.beyondEndOfImage = "客户机尝试读取超出磁盘映像末尾的范围。%1$s 处的映像不完整或已损坏。|0A"
msg.cdrom.connectDir = "无法将 CD-ROM 连接到后端「%1$s」。目录不能用作 CD-ROM 映像。|0A"
msg.cdrom.ejectFail = "无法从 CD-ROM 驱动器中弹出光盘。|0A错误：%1$s。|0A请确认 CD-ROM 未被主机使用或连接到其他虚拟机。|0A"
msg.cdrom.lockfail = "CD-ROM 正在被其他进程读取。原因可能是 CD-ROM 自动播放功能已启用，或资源管理器中打开了 CD-ROM。这可能导致在虚拟机中读取 CD-ROM 时出现问题。在允许虚拟机读取 CD-ROM 之前，请先停止其他进程的读取操作。|0A如果立 执行此操作，请选择「%1$s」选项。如果稍后执行，请选择「%2$s」选项，待准备就绪后重新连接 CD-ROM。选择「%3$s」可忽略以后的所有此类错误。|0A"
msg.cdrom.notImplemented = "虚拟机发送了传统模拟不支持的 CD-ROM 命令。|0A命令包：%1$s|0A这不是致命错误，但应用程序可能无法访问 CD-ROM。请尝试在不使用传统模拟的情况下运行此虚拟机。"
msg.cdrom.notImplementedBug = "此问题已作为内部功能请求 %1$d 报告。|0A"
msg.cdrom.notImplementedEmpty = " "
msg.cdrom.unlockfail = "CD-ROM 驱动器门解锁失败。客户机操作系统可能会混淆驱动器的状态。|0A"
msg.cdromGeneric.openFailed = "连接到设备 %1$s 失败：%2$s。"
msg.cdromGenericConnect.getlockfail = "获取 CD-ROM 锁定状态失败。如果虚拟机关闭，主机操作系统可能会错误地解释驱动器的状态。"
msg.cdromGenericConnect.lockfail = "重新获取 CD-ROM 锁定失败。客户机操作系统可能错误地解释了驱动器的状态。|0A"
msg.cdromImage.cantOpen = "文件「%1$s」无法作为 CD-ROM 映像连接：%2$s|0A"
msg.cdromImage.disconnect = "CD-ROM 映像文件 %1$s 操作失败。如果不修复映像文件连接，后续对该文件的操作也可能失败。请断开映像文件，然后尝试重新连接到虚拟机的 CD-ROM 驱动器。要继续向客户机操作系统传递错误，请选择 %2$s。要断开映像文件，请选择 %3$s。|0A"
msg.cdromImage.needLargeFS = "|22%1$s|22 的文件大小无法正确确定。完整大小超过 2GB，超出了文件系统的大小限制。|0A有关详细信息，请参阅 %2$s 知识库。|0A"
msg.cdromImage.sigFailed = "无法验证 ISO 映像的签名。ISO 映像文件「%1$s」的签名验证失败。请确认映像文件未损坏且有有效的签名文件。如果正在复制此映像，请等待复制完成后再连接映像。|0A"
msg.cdromImage.sizeChanged = "您的 ISO 映像大小已更改。ISO 映像文件「%1$s」已从 %2$I64u 字节更改为 %3$I64u 字节。如果正在复制此映像，请等待复制完成后再连接映像。|0A"
msg.cdromImage.tooLargeIso = "您的 ISO 映像大小过大。ISO 映像文件「%1$s」超过了可访问的上限 4 GB，只能访问 4GB。这可能是由于远程文件服务器存在问题。要解决此问题，请使用本地 ISO 映像。|0A有关详细信息，请参阅 %2$s 知识库。|0A"
msg.cdromdisconnect.locked = "客户机操作系统可能已锁定 CD-ROM 门并使用 CD-ROM。因此客户机无法感知介质更换。如有可能，请在断开连接前从客户机内部弹出 CD-ROM。|0A|0A是否仍然断开连接并忽略锁定？|0A"
msg.cdromdisconnect.locked.darwin = "此操作无法继续，因为 Mac OS 客户机正在使用 CD/DVD。|0A|0A请关闭此消息，从客户机内弹出光盘，然后重试此操作。"
