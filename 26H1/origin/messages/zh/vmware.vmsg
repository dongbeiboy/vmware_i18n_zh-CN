msg.hvuser.NoSVM = "此主机不支持 AMD-V。"
msg.hvuser.NoVT = "此主机不支持 Intel VT-x。"
msg.hvuser.SVMConfig = "此虚拟机配置不支持 AMD-V 操作。"
msg.hvuser.SVMDisabled = "此主机支持 AMD-V，但 AMD-V 已被禁用。|0AAMD-V 可能在 BIOS/固件设置中被禁用，或者更改此设置后未重新通电。|0A(1) 请确保 BIOS/固件设置中已启用 AMD-V。|0A(2) 更改 BIOS/固件设置后，请重新启动主机电源。|0A(3) 如果安装 %1$s 后尚未重新启动主机电源，请重新启动主机电源。|0A(4) 请将主机 BIOS/固件更新到最新版本。"
msg.hvuser.SVMUnsupported = "此主机支持 AMD-V，但 AMD-V 的实现与 %1$s 不兼容。"
msg.hvuser.VTConfig = "此虚拟机配置不支持 Intel VT-x 操作。"
msg.hvuser.VTDisabled = "此主机支持 Intel VT-x，但 Intel VT-x 已被禁用。|0AIntel VT-x 可能在 BIOS/固件设置中被禁用，或者更改此设置后未重新通电。|0A(1) 请确保 BIOS/固件设置中已启用 Intel VT-x，并禁用「可信执行」。|0A(2) 更改这些 BIOS/固件设置中的任一设置后，请重新启动主机电源。|0A(3) 如果安装 %1$s 后尚未重新启动主机电源，请重新启动主机电源。|0A(4) 请将主机 BIOS/固件更新到最新版本。"
msg.hvuser.VTRestricted = "此主机支持 Intel VT-x，但 Intel VT-x 受到限制。|0ABIOS/固件设置中启用了「可信执行」，或者更改此设置后未重新通电，可能导致 Intel VT-x 受限。|0A(1) 请确保 BIOS/固件设置中已启用 Intel VT-x，并禁用「可信执行」。|0A(2) 更改这些 BIOS/固件设置中的任一设置后，请重新启动主机电源。|0A(3) 如果安装 %1$s 后尚未重新启动主机电源，请重新启动主机电源。|0A(4) 请将主机 BIOS/固件更新到最新版本。"
msg.hvuser.VTUnlocked = "此主机支持 Intel VT-x，但 Intel VT-x 未被锁定。|0A可能需要更新 BIOS/固件。|0A(1) 请确保 BIOS/固件设置中已启用 Intel VT-x，并禁用「可信执行」。|0A(2) 更改这些 BIOS/固件设置中的任一设置后，请重新启动主机电源。|0A(3) 如果安装 %1$s 后尚未重新启动主机电源，请重新启动主机电源。|0A(4) 请将主机 BIOS/固件更新到最新版本。"
