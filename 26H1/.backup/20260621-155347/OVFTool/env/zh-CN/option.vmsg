###
### These are the VSAN iSCSI Target (VIT) Advanced Settings
###
EsxHostAdvSettings.VSAN-iSCSI.iscsiPingTimeout.label= "iscsiPingTimeout"
EsxHostAdvSettings.VSAN-iSCSI.iscsiPingTimeout.summary= "ping (NOP-Out) 请求之间的间隔（秒）"

###
###
### These are the iSCSI Advanced Settings
###
### They are the only advanced option keys that do not have a prefix.
### This is so for backwards compatibility.
###

###
EsxHostAdvSettings.DefaultTimeToRetain.label= "DefaultTimeToRetain"
EsxHostAdvSettings.DefaultTimeToRetain.summary= "iSCSI 选项：连接终止或重置后，仍可进行连接和任务关联恢复的最长时间（秒）"
EsxHostAdvSettings.DefaultTimeToWait.label= "DefaultTimeToWait"
EsxHostAdvSettings.DefaultTimeToWait.summary= "iSCSI 选项：意外连接终止或重置后，尝试注销或活动任务重新分配前的最短等待时间（秒）"
EsxHostAdvSettings.DelayedAck.label= "DelayedAck"
EsxHostAdvSettings.DelayedAck.summary= "iSCSI 选项：是否允许启动器延迟确认接收的数据包"
EsxHostAdvSettings.ErrorRecoveryLevel.label= "ErrorRecoveryLevel"
EsxHostAdvSettings.ErrorRecoveryLevel.summary= "iSCSI 选项：ESX 启动器在登录期间协商的 iSCSI 错误恢复级别 (ERL) 值"
EsxHostAdvSettings.FirstBurstLength.label= "FirstBurstLength"
EsxHostAdvSettings.FirstBurstLength.summary= "iSCSI 选项：启动器在执行单个 SCSI 命令期间可发送的最大未经请求数据字节数。必须 <= MaxBurstLength"
EsxHostAdvSettings.ImmediateData.label= "ImmediateData"
EsxHostAdvSettings.ImmediateData.summary= "iSCSI 选项：是否允许启动器向目标发送立 （未经请求）数据"
EsxHostAdvSettings.InitR2T.label= "InitR2T"
EsxHostAdvSettings.InitR2T.summary= "iSCSI 选项：是否允许启动器在收到初始 R2T 之前就向目标开始发送数据"
EsxHostAdvSettings.LoginRetryMax.label= "LoginRetryMax"
EsxHostAdvSettings.LoginRetryMax.summary= "iSCSI 选项：ESX 启动器在放弃前重试登录目标的最大次数"
EsxHostAdvSettings.LoginTimeout.label= "LoginTimeout"
EsxHostAdvSettings.LoginTimeout.summary= "iSCSI 选项：启动器等待登录响应完成的时间（秒）"
EsxHostAdvSettings.LogoutTimeout.label= "LogoutTimeout"
EsxHostAdvSettings.LogoutTimeout.summary= "iSCSI 选项：启动器等待注销请求 PDU 响应的最长时间（秒）"
EsxHostAdvSettings.MaxBurstLength.label= "MaxBurstLength"
EsxHostAdvSettings.MaxBurstLength.summary= "iSCSI 选项：Data-In 或有请求的 Data-Out iSCSI 序列中的最大 SCSI 数据负载（字节）"
EsxHostAdvSettings.MaxCommands.label= "MaxCommands"
EsxHostAdvSettings.MaxCommands.summary= "iSCSI 选项：可在 iSCSI 适配器上排队的最大 SCSI 命令数"
EsxHostAdvSettings.MaxOutstandingR2T.label= "MaxOutstandingR2T"
EsxHostAdvSettings.MaxOutstandingR2T.summary= "iSCSI 选项：一个任务可以拥有的最大未完成 R2T (Ready To Transfer) PDU 数量"
EsxHostAdvSettings.MaxRecvDataSegLen.label= "MaxRecvDataSegLen"
EsxHostAdvSettings.MaxRecvDataSegLen.summary= "iSCSI 选项：可在单个 iSCSI PDU 中接收的最大数据段长度（字节）。建议保持 <= MaxBurstLength"
EsxHostAdvSettings.NoopInterval.label= "NoopInterval"
EsxHostAdvSettings.NoopInterval.summary= "iSCSI 选项：启动器发送 NOP-OUT 以验证连接仍处于活动状态的间隔时间（秒）"
EsxHostAdvSettings.NoopTimeout.label= "NoopTimeout"
EsxHostAdvSettings.NoopTimeout.summary= "iSCSI 选项：启动器从目标接收 NOP-IN PDU 前可经过的最长时间（秒）。超过无操作超时限制时，启动器将终止当前连接并启动新连接"
EsxHostAdvSettings.RecoveryTimeout.label= "RecoveryTimeout"
EsxHostAdvSettings.RecoveryTimeout.summary= "iSCSI 选项：执行会话恢复时可经过的最长时间（秒）。如果在此时间内会话恢复未完成，启动器将终止会话"

