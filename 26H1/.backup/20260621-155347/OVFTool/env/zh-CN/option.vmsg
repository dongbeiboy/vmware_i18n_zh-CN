EsxHostAdvSettings.Syslog.global.logCheckSSLCerts.label= "Syslog.global.logCheckSSLCerts"
EsxHostAdvSettings.Syslog.global.logCheckSSLCerts.summary= "已弃用 - 请使用 Syslog.global.certificate.checkSSLCerts。在向远程主机传输消息时强制执行 SSL 证书检查"
EsxHostAdvSettings.Syslog.global.logDir.label= "Syslog.global.logDir"
EsxHostAdvSettings.Syslog.global.logDir.summary= "日志输出目录的数据存储路径。示例：[datastoreName]/logdir"
EsxHostAdvSettings.Syslog.global.logDirUnique.label= "Syslog.global.logDirUnique"
EsxHostAdvSettings.Syslog.global.logDirUnique.summary= "启用将日志文件放置在 logdir 中基于主机名的唯一子目录中"
EsxHostAdvSettings.Syslog.global.logFilters.label= "Syslog.global.logFilters"
EsxHostAdvSettings.Syslog.global.logFilters.summary= "以双竖线 (||) 分隔的日志过滤器列表。日志过滤器的格式为：numLogs | ident | logRegexp。'numLogs' 设置指定日志消息的最大日志条目数，达到该数量后，指定日志消息将被过滤并忽略。'ident' 指定一个或多个系统组件，用于将过滤器应用于这些组件生成的日志消息。'logRegexp' 指定区分大小写的短语，使用 Python 正则表达式语法按内容过滤日志消息"
EsxHostAdvSettings.Syslog.global.logFiltersEnable.label= "Syslog.global.logFiltersEnable"
EsxHostAdvSettings.Syslog.global.logFiltersEnable.summary= "启用日志过滤器功能"
EsxHostAdvSettings.Syslog.global.logHost.label= "Syslog.global.logHost"
EsxHostAdvSettings.Syslog.global.logHost.summary= "以逗号 (,) 分隔的远程主机列表，用于传输消息。格式为：proto://主机名|ipv4|'['ipv6']'[:端口][?formatter=value[&framing=value]]。协议必须是 (tcp|udp|ssl) 之一。如果未提供端口，ssl 和 tcp 将使用 1514，udp 将使用 514。格式化程序必须是 (RFC_3164|RFC_5424) 之一。组帧必须是 (octet_counting|non_transparent) 之一。默认格式化程序为 RFC 3164，默认组帧为 non_transparent"
EsxHostAdvSettings.Syslog.global.logLevel.label= "Syslog.global.logLevel"
EsxHostAdvSettings.Syslog.global.logLevel.summary= "日志过滤级别。仅在排查系统日志守护程序问题时应更改。值可以是 'debug'（最详细级别）、'info'（默认详细级别）、'warning'（仅警告或错误）或 'error'（仅错误）"
EsxHostAdvSettings.Syslog.global.msgQueueDropMark.label= "Syslog.global.msgQueueDropMark"
EsxHostAdvSettings.Syslog.global.msgQueueDropMark.summary= "消息队列丢弃标记（百分比）"
EsxHostAdvSettings.Syslog.global.remoteHost.maxMsgLen.label= "Syslog.global.remoteHost.maxMsgLen"
EsxHostAdvSettings.Syslog.global.remoteHost.maxMsgLen.summary= "使用 TCP 和 TLS (SSL) 协议时的远程主机最大传输长度（字节）。超过此长度的消息将被截断"
EsxHostAdvSettings.Syslog.global.remoteHost.connectRetryDelay.label= "Syslog.global.remoteHost.connectRetryDelay"
EsxHostAdvSettings.Syslog.global.remoteHost.connectRetryDelay.summary= "连接尝试失败后重试连接远程主机前的延迟（秒）"
EsxHostAdvSettings.Syslog.global.stdMsg.poolSize.label= "Syslog.global.stdMsgPoolSize"
EsxHostAdvSettings.Syslog.global.stdMsg.poolSize.summary= "标准消息内存池的大小（MiB）"
