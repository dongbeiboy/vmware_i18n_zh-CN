counter.cpu.capacity.provisioned.summary                          = "物理 CPU 内核的容量（MHz）"
counter.cpu.capacity.provisioned.DPU.label="CPU 容量 已置备"
counter.cpu.capacity.provisioned.DPU.summary                      = "数据处理单元的标称容量（MHz）"
counter.cpu.capacity.provisioned.HOST.label="CPU 容量 已置备"
counter.cpu.capacity.provisioned.HOST.summary                     = "Nominal 物理 CPU 内核的容量（MHz） without taking into account any possible 频率 boost of hyper-threading enabled"
counter.cpu.capacity.usage.label="CPU 容量 使用率"
counter.cpu.capacity.usage.summary                                = "CPU 使用率 as a 百分比 during the 间隔"
counter.cpu.capacity.usage.DPU.label="CPU 容量 使用率"
counter.cpu.capacity.usage.DPU.summary                            = "CPU 使用率（MHz） of the entire 数据处理单元 during the last 测量 间隔. Can be higher than the reported 已置备 容量 due to enabled hyper-threading and/or 处理器 running into 频率 boost mode"
counter.cpu.capacity.usage.HOST.label="CPU 容量 使用率"
counter.cpu.capacity.usage.HOST.summary                           = "CPU 使用率（MHz） of the entire 主机 during the last 测量 间隔. Can be higher than the reported 已置备 容量 due to enabled hyper-threading and/or 处理器 running into 频率 boost mode"
counter.cpu.capacity.usage.VM.label="CPU 容量 使用率"
counter.cpu.capacity.usage.VM.summary                             = "CPU 使用率（MHz） for this 虚拟 machine during the last 测量 间隔, based on the 数字 of 虚拟 CPUs running. Can be higher than the reported 已置备 容量 due to enabled hyper-threading and/or 处理器 running into 频率 boost mode"
counter.cpu.coreUtilization.label="Core 利用率"
counter.cpu.coreUtilization.summary                               = "CPU 利用率 of the corresponding core (if hyper-threading is enabled) as a 百分比 during the 间隔 (A core is utilized if either or both of its logical CPUs are utilized)"
counter.cpu.corecount.contention.label                            = "CPU 内核计数争用"
counter.cpu.corecount.contention.summary                          = "时间 the VM vCPU is 就绪 to run, but is unable to run due to co-scheduling constraints"
counter.cpu.corecount.contention.HOST.label                       = "CPU 内核计数争用"
counter.cpu.corecount.contention.HOST.summary                     = "Aggregated 时间 of all vCPUs which are 就绪 to run, but is unable to run due to co-scheduling constraints, in 百分比"
counter.cpu.corecount.contention.VM.label                         = "CPU 内核计数争用"
counter.cpu.corecount.contention.VM.summary                       = "时间 the VM is 就绪 to run, but is unable to run due to co-scheduling constraints"
counter.cpu.corecount.contention.VM.VCPU.label                    = "CPU 内核计数争用"
counter.cpu.corecount.contention.VM.VCPU.summary                  = "时间 the VM vCPU is 就绪 to run, but is unable to run due to co-scheduling constraints"
counter.cpu.corecount.provisioned.label="CPU Core 计数 已置备"
counter.cpu.corecount.provisioned.summary                         = "预配给实体的虚拟处理器数"
counter.cpu.corecount.provisioned.DPU.label="CPU Core 计数 已置备"
counter.cpu.corecount.provisioned.DPU.summary                     = "数据处理单元上的物理处理器数"
counter.cpu.corecount.provisioned.HOST.label="CPU Core 计数 已置备"
counter.cpu.corecount.provisioned.HOST.summary                    = "预配给实体的物理内核数"
counter.cpu.corecount.provisioned.VM.label="CPU Core 计数 已置备"
counter.cpu.corecount.provisioned.VM.summary                      = "预配给实体的虚拟处理器数"
counter.cpu.corecount.usage.label="CPU Core 计数 使用率"
counter.cpu.corecount.usage.summary                               = "主机上运行的虚拟处理器数"
counter.cpu.corecount.usage.HOST.label="CPU Core 计数 使用率"
counter.cpu.corecount.usage.HOST.summary                          = "主机上运行的虚拟处理器数"
counter.cpu.corecount.usagePct.label="CPU Core 计数 使用率"
counter.cpu.corecount.usagePct.summary                            = "主机上运行的虚拟处理器数, as a 百分比 of the 数字 of 物理 cores"
counter.cpu.costop.label="Co-stop"
counter.cpu.costop.summary                                        = "时间 the 虚拟 machine is 就绪 to run, but is unable to run due to co-scheduling constraints"
counter.cpu.costop.RESPOOL.label="%CSTP"
counter.cpu.costop.RESPOOL.summary                                = "The 百分比 (denormalized from 0% up to 100xNumWorlds%) of 时间 the worlds of this 资源 池 / scheduling group spent in 就绪, co-deschedule 状态. Returned only for SMP VMs"
counter.cpu.cpuentitlement.label                                  = "最差情况分配"
counter.cpu.cpuentitlement.summary                                = "量 of CPU resources allocated to the 虚拟 machine or 资源 池, based on the 总计 集群 容量 and the 资源 configuration of the 资源 hierarchy"
counter.cpu.dem和.label="Dem和"
counter.cpu.dem和.summary="The a挂载 of CPU 资源 a 虚拟机 would use if there were no CPU contention or CPU 限制"
counter.cpu.dem和EntitlementRatio.label="需求-to- entitlement  ratio"
counter.cpu.dem和EntitlementRatio.summary="CPU 资源  entitlement  to CPU 需求 ratio (百分比s)"
counter.cpu.entitlement.label="Entitlement"
counter.cpu.entitlement.summary                                   = "CPU resources devoted by the ESX 调度程序"
counter.cpu.extra.label="Extra"
counter.cpu.extra.summary                                         = "额外 CPU 时间"
counter.cpu.guaranteed.label="Guaranteed"
counter.cpu.guaranteed.summary                                    = "为实体预留的 CPU 时间"
counter.cpu.idle.label="Idle"
counter.cpu.idle.summary                                          = "CPU 处于空闲状态的总时间"
counter.cpu.latency.label="Latency"
counter.cpu.latency.summary                                       = "百分比 of 时间 the 虚拟 machine is unable to run because it is contending for access to the 物理 CPU(s)"
counter.cpu.load.avg15min.label                                   = "CPU 负载平均值（15 分钟）"
counter.cpu.load.avg15min.summary                                 = "CPU 负载 平均 over the past 15 minutes, sampled on every 6 秒s"
