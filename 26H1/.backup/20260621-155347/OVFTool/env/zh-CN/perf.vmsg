counter.cpu.load.avg15min.HOST.summary                            = "CPU 负载 平均 over the past 15 minutes, sampled on every 6 秒s"
counter.cpu.load.avg1min.label                                    = "CPU 负载平均值（1 分钟）"
counter.cpu.load.avg1min.summary                                  = "CPU 负载 平均 over the past 1 minute, sampled on every 6 秒s"
