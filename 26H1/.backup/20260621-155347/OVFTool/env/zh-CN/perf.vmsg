counter.cpu.capacity.entitlement.label                            = "CPU 容量权利"
counter.cpu.capacity.entitlement.summary                          = "CPU resources devoted by the ESXi 调度程序 to the 虚拟 machines and 资源 pools"
counter.cpu.capacity.entitlement.VM.label                         = "CPU 容量权利"
counter.cpu.capacity.entitlement.VM.summary                       = "CPU resources devoted by the ESXi 调度程序 to the 虚拟 machines and 资源 pools"
