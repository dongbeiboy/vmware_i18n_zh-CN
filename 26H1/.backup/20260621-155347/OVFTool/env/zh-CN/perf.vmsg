counter.cpu.load.avg1min.HOST.summary                             = "CPU 负载 平均 over the past 1 minute, sampled on every 6 秒s"
counter.cpu.load.avg5min.label                                    = "CPU 负载平均值（5 分钟）"
counter.cpu.load.avg5min.summary                                  = "CPU 负载 平均 over the past 5 minutes, sampled on every 6 秒s"
