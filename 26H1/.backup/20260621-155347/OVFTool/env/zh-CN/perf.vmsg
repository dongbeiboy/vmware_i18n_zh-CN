counter.cpu.load.avg5min.HOST.summary                             = "CPU 负载 平均 over the past 5 minutes, sampled on every 6 秒s"
counter.cpu.maxlimited.label="Max 限制ed"
counter.cpu.maxlimited.summary                                    = "时间 the 虚拟 machine is 就绪 to run, but is not run due to maxing out its CPU 限制 setting"
counter.cpu.maxlimited.RESPOOL.label="%MLMTD"
counter.cpu.maxlimited.RESPOOL.summary                            = "The 百分比 (denormalized from 0% up to 100xNumWorlds%) of 时间 the worlds of this 资源 池 / scheduling group was 就绪 to run but deliberately wasn't scheduled because they are violate the 'CPU 限制' settings. Note that %MLMTD is included in %RDY"
counter.cpu.overlap.label="Overlap"
counter.cpu.overlap.summary                                       = "时间 the 虚拟 machine was interrupted to perform 系统 服务 on behalf of itself or other 虚拟 machines"
counter.cpu.partnerBusyTime.label                                 = "PCPU 合作伙伴繁忙时间 (%)"
counter.cpu.partnerBusyTime.summary                               = "The 百分比 HT partner 使用率 per 物理 CPU"
counter.cpu.partnerBusyTime.PCPU.label                            = "PCPU 合作伙伴繁忙时间 (%)"
counter.cpu.partnerBusyTime.PCPU.summary                          = "The 百分比 HT partner 使用率 per 物理 CPU"
counter.cpu.readiness.label="Readiness"
counter.cpu.readiness.summary                                     = "百分比 of 时间 that the 虚拟 machine was 就绪, but could not get scheduled to run on the 物理 CPU"
counter.cpu.ready.label="Ready"
counter.cpu.ready.summary                                         = "时间 that the 虚拟 machine was 就绪, but could not get scheduled to run on the 物理 CPU during last 测量 间隔"
counter.cpu.ready.RESPOOL.label="%RDY"
counter.cpu.ready.RESPOOL.summary                                 = "Accounts the 百分比 (denormalized from 0% up to 100xNumWorlds%) of 时间 that all of the worlds from this 资源 group / scheduling group are spending in run-队列 就绪 to be run, but unable to be scheduled"
counter.cpu.reserved.label="Reserved"
counter.cpu.reserved.summary="CPU 已预留"
counter.cpu.reservedCapacity.label="已预留 容量"
counter.cpu.reservedCapacity.summary="总计 CPU 容量 已预留 by 虚拟机s"
counter.cpu.reservedcapacity.label="已预留 容量"
counter.cpu.reservedcapacity.summary="总计 CPU 容量 已预留 by 虚拟机s"
counter.cpu.run.label="Run"
counter.cpu.run.summary                                           = "时间 the 虚拟 machine is scheduled to run"
counter.cpu.run.RESPOOL.label="%RUN"
counter.cpu.run.RESPOOL.summary                                   = "The 百分比 (denormalized from 0% up to 100xNumWorlds%) of 总计 scheduled 时间 for the 资源 池 / scheduling group to run (%USED = %RUN + %SYS - %OVRLP)"
counter.cpu.runav1.label                                          = "正在运行（1 分钟平均）"
counter.cpu.runav1.summary                                        = "1 分钟内的 CPU 运行平均值"
counter.cpu.runav15.label                                         = "正在运行（15 分钟平均）"
counter.cpu.runav15.summary                                       = "15 分钟内的 CPU 运行平均值"
counter.cpu.runav5.label                                          = "正在运行（5 分钟平均）"
counter.cpu.runav5.summary                                        = "5 分钟内的 CPU 运行平均值"
counter.cpu.swapwait.label                                        = "交换等待"
counter.cpu.swapwait.summary                                      = "CPU 时间 spent waiting for 交换-in"
counter.cpu.swapwait.RESPOOL.label="%SWPWT"
counter.cpu.swapwait.RESPOOL.summary                              = "The 百分比 (denormalized from 0% up to 100xNumWorlds%) of 时间 the worlds of this 资源 池 / scheduling group are waiting for the ESX VMKernel swapping 内存. The 交换等待 时间 is included in the %等待 时间"
counter.cpu.system.label="System"
counter.cpu.system.summary                                        = "量 of 时间 spent on 系统 processes on each 虚拟 CPU in the 虚拟 machine"
counter.cpu.totalCapacity.label="总计 容量"
counter.cpu.totalCapacity.summary                                 = "虚拟机预留并可用的总 CPU 容量"
counter.cpu.totalmhz.label="Total"
counter.cpu.totalmhz.summary                                      = "集群中所有主机的 CPU 资源总量"
counter.cpu.usage.label="Usage"
counter.cpu.usage.summary                                         = "间隔期间 CPU 使用率百分比"
counter.cpu.usage.DPU.label="Usage"
counter.cpu.usage.DPU.summary                                     = "CPU 使用率 on the 数据处理单元 as a 百分比 during the 间隔"
counter.cpu.usage.DPU.PCPU.label="Usage"
counter.cpu.usage.DPU.PCPU.summary                                = "CPU 使用率 of 物理 CPU on the 数据处理单元 as a 百分比 during the 间隔"
counter.cpu.usage.HOST.label                                      = "PCPU USED(%)"
counter.cpu.usage.HOST.summary                                    = "Normalized (0 to 100%) CPU 使用率 across all of the 物理 CPUs on the 主机"
counter.cpu.usage.PCPU.label                                      = "PCPU USED(%)"
counter.cpu.usage.PCPU.summary                                    = "The 百分比 CPU 使用率 per 物理 CPU"
counter.cpu.usage.RESPOOL.label="%已用"
counter.cpu.usage.RESPOOL.summary                                 = "CPU 使用率 (in 百分比 denormalized from 0% up to 100xNumWorlds%) for this 资源 池 / scheduling group during last 测量 间隔"
counter.cpu.usage.vcpus.label="vCPU 使用率"
counter.cpu.usage.vcpus.summary                                   = "间隔期间虚拟 CPU 使用率百分比"
counter.cpu.usagemhz.label="使用率 in MHz"
counter.cpu.usagemhz.summary                                      = "间隔期间 CPU 使用率（兆赫）"
counter.cpu.used.label="Used"
counter.cpu.used.summary="总计 CPU 使用率"
counter.cpu.utilization.label="Utilization"
counter.cpu.utilization.summary                                   = "CPU 利用率 as a 百分比 during the 间隔 (CPU 使用率 and CPU 利用率 might be different due to 电源 管理 technologies or hyper-threading)"
counter.cpu.utilization.PCORE.label="CORE UTIL(%)"
counter.cpu.utilization.PCORE.summary                             = "The 百分比 of CPU cycles per core when at least one of the PCPUs in this core is unhalted. It's the reverse of the core 空闲, which is the 百分比 of CPU cycles when all PCPUs in this core are halted. Effectively, equal to cpu.利用率 per PCPU when hyper-threading is not used"
counter.cpu.utilization.PCPU.label="PCPU UTIL(%)"
counter.cpu.utilization.PCPU.summary                              = "The 百分比 of unhalted CPU cycles per 物理 CPU"
counter.cpu.wait.label="Wait"
counter.cpu.wait.summary                                          = "等待状态下花费的 CPU 总时间"
counter.cpu.wait.RESPOOL.label="%WAIT"
counter.cpu.wait.RESPOOL.summary                                  = "This is the 总计 等待 时间 (in 百分比 denormalized from 0% up to 100xNumWorlds%). I.e., the 资源 池 / scheduling group is waiting for some VMKernel 资源. This 等待 时间 includes I/O 等待 时间, 空闲 时间 and among other resources"
