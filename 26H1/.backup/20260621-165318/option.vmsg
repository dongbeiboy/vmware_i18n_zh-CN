###
### These are the VSAN iSCSI Target (VIT) Advanced Settings
###
EsxHostAdvSettings.VSAN-iSCSI.iscsiPingTimeout.label="iscsiPingTimeout"
EsxHostAdvSettings.VSAN-iSCSI.iscsiPingTimeout.summary="间隔 介于 ping (NOP-Out) requests, in 秒"

###
###
### These are the iSCSI Advanced Settings
###
### They are the only advanced option keys that do not have a prefix.
### This is so for backwards compatibility.
###

###
EsxHostAdvSettings.DefaultTimeToRetain.label="DefaultTimeToRetain"
EsxHostAdvSettings.DefaultTimeToRetain.summary="iSCSI option : Maximum 秒 that a 连接ion 和 任务 allegiance rein状态ment is still possible following a 连接ion termination or 重置."
EsxHostAdvSettings.DefaultTimeToWait.label="DefaultTimeToWait"
EsxHostAdvSettings.DefaultTimeToWait.summary="iSCSI option : Minimum 秒 to wait before attempting a 注销 or an 活动 任务 re分配ment after an unexpected 连接ion termination or 重置."
EsxHostAdvSettings.DelayedAck.label="DelayedAck"
EsxHostAdvSettings.DelayedAck.summary="iSCSI option : Whether to allow initiator to 延迟 acknowledgement of 已接收 data 数据包."
EsxHostAdvSettings.ErrorRecoveryLevel.label="ErrorRecoveryLevel"
EsxHostAdvSettings.ErrorRecoveryLevel.summary="iSCSI option : iSCSI 错误 Recovery Level (ERL) 值 that the ESX initiator would negotiate during 登录."
EsxHostAdvSettings.FirstBurstLength.label="FirstBurstLength"
EsxHostAdvSettings.FirstBurstLength.summary="iSCSI option : Maximum unsolicited data （字节） initiator can send during the execution of a single SCSI command. It must be <= MaxBurstLength."
EsxHostAdvSettings.ImmediateData.label="ImmediateData"
EsxHostAdvSettings.ImmediateData.summary="iSCSI option : Whether to allow initiator to send immediate (unsolicited) data 到 target."
EsxHostAdvSettings.InitR2T.label="InitR2T"
EsxHostAdvSettings.InitR2T.summary="iSCSI option : Whether to allow initiator to start sending data to a target as if it had 已接收 an initial R2T."
EsxHostAdvSettings.LoginRetryMax.label="LoginRetryMax"
EsxHostAdvSettings.LoginRetryMax.summary="iSCSI option : Maximum number of times ESX initiator would 重试 登录 to a target, before giving up."
EsxHostAdvSettings.LoginTimeout.label="LoginTimeout"
EsxHostAdvSettings.LoginTimeout.summary="iSCSI option : Time in 秒 initiator will wait 的 登录 response to finish."
EsxHostAdvSettings.LogoutTimeout.label="LogoutTimeout"
EsxHostAdvSettings.LogoutTimeout.summary="iSCSI option : Time in 秒 initiator will wait to get a response for 注销 request PDU"
EsxHostAdvSettings.MaxBurstLength.label="MaxBurstLength"
EsxHostAdvSettings.MaxBurstLength.summary="iSCSI option : Maximum SCSI data pay加载 （字节） in a Data-In or a solicited Data-Out iSCSI sequence."
EsxHostAdvSettings.MaxCommands.label="MaxCommands"
EsxHostAdvSettings.MaxCommands.summary="iSCSI option : Maximum SCSI commands that can be 已排队 在 iSCSI adpater."
EsxHostAdvSettings.MaxOutstandingR2T.label="MaxOutstandingR2T"
EsxHostAdvSettings.MaxOutstandingR2T.summary="iSCSI option : Maximum number of R2T (Ready To Transfer) PDUs, that can be outstanding for a 任务."
EsxHostAdvSettings.MaxRecvDataSegLen.label="MaxRecvDataSegLen"
EsxHostAdvSettings.MaxRecvDataSegLen.summary="iSCSI option : Maximum data segment length （字节） that can be 已接收 in an iSCSI PDU. It is recommended to keep it <= MaxBurstLength."
EsxHostAdvSettings.NoopInterval.label="NoopInterval"
EsxHostAdvSettings.NoopInterval.summary="iSCSI option : Time in 秒 in 介于 NOP-OUTs sent by the initiator to 验证 that a 连接ion is still 活动."
EsxHostAdvSettings.NoopTimeout.label="NoopTimeout"
EsxHostAdvSettings.NoopTimeout.summary="iSCSI option : Time in 秒 that can elapse before initiator 接收s a NOP-IN PDU 从 target. When no-op 超时 限制 is exceeded, initiator terminates the 电流 连接ion 和 starts a new one."
EsxHostAdvSettings.RecoveryTimeout.label="RecoveryTimeout"
EsxHostAdvSettings.RecoveryTimeout.summary="iSCSI option : Time in 秒 that can elapse while a session recovery is performed. If the session recovery 不 over within this time, initiator terminates the session."

