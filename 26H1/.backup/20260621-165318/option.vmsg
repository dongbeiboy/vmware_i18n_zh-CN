EsxHostAdvSettings.Config.HostAgent.plugins.solo.disableRemoteEsxcli.summary="启用s or 禁用s remote execution of esxcli commands."
EsxHostAdvSettings.Config.HostAgent.plugins.hostsvc.esxAdminsGroup.label="plugins.主机svc.esxAdmins组"
EsxHostAdvSettings.Config.HostAgent.plugins.hostsvc.esxAdminsGroup.summary="Active Directory 组 名称 —— automatically granted administrator 特权s 在 ESX. 注意： 正在更改 the 组 名称 does not 移除 the 权限s 的 上一个 组."
EsxHostAdvSettings.Config.HostAgent.plugins.hostsvc.esxAdminsGroupAutoAdd.label="plugins.主机svc.esxAdmins组Auto添加"
EsxHostAdvSettings.Config.HostAgent.plugins.hostsvc.esxAdminsGroupAutoAdd.summary="Controls whether the 组 specified by 'esxAdmins组' is automatically granted administrator 权限. 注意： 正在更改 this to false does not 移除 any 权限s already granted 到 组."
EsxHostAdvSettings.Config.HostAgent.plugins.hostsvc.esxAdminsGroupUpdateInterval.label="plugins.主机svc.esxAdmins组更新间隔"
EsxHostAdvSettings.Config.HostAgent.plugins.hostsvc.esxAdminsGroupUpdateInterval.summary="间隔 介于 checks for whether the 组 specified by 'esxAdmins组' has appeared in Active Directory, in 分钟."
EsxHostAdvSettings.Config.HostAgent.plugins.vimsvc.authValidateInterval.label="plugins.vimsvc.auth验证间隔"
EsxHostAdvSettings.Config.HostAgent.plugins.vimsvc.authValidateInterval.summary="所有已知用户和组的每次验证之间的分钟数 - 设为零可禁用验证."
EsxHostAdvSettings.Config.HostAgent.plugins.vimsvc.enableUtf8Filter.label="plugins.vimsvc.启用Utf8Filter"
EsxHostAdvSettings.Config.HostAgent.plugins.vimsvc.enableUtf8Filter.summary="启用 UTF-8 验证 of VIM API responses."
EsxHostAdvSettings.Config.HostAgent.plugins.vimsvc.httpNfcLeaseTimeout.label="plugins.vimsvc.httpNfcLease超时"
EsxHostAdvSettings.Config.HostAgent.plugins.vimsvc.httpNfcLeaseTimeout.summary="Number of 秒 until an HTTP NFC lease times out due to inactivity. Applies to new leases only."
EsxHostAdvSettings.Config.HostAgent.plugins.vimsvc.disableHostProfileApi.label="启用s or 禁用s 主机 Profile pyEngine APIs."
EsxHostAdvSettings.Config.HostAgent.plugins.vimsvc.disableHostProfileApi.summary="启用s or 禁用s 主机 Profile pyEngine APIs. 重新启动 主机 代理 服务 (主机d) to adopt new 值."
EsxHostAdvSettings.Config.HostAgent.plugins.vimsvc.userSearch.maxResults.label="plugins.vimsvc.用户Search.maxResults"
EsxHostAdvSettings.Config.HostAgent.plugins.vimsvc.userSearch.maxResults.summary="在添加权限对话框中显示的最大用户和组数 - 设置 to zero to 禁用 the 限制."
EsxHostAdvSettings.Config.HostAgent.plugins.vimsvc.userSearch.maxTimeSeconds.label="plugins.vimsvc.用户Search.maxTime秒"
EsxHostAdvSettings.Config.HostAgent.plugins.vimsvc.userSearch.maxTimeSeconds.summary="等待用户和组搜索返回结果的秒数 - 设置 to zero to 禁用 the 超时."
EsxHostAdvSettings.Config.HostAgent.plugins.vmsvc.blockDiskRemoveIfSnapshot.label="plugins.vmsvc.块磁盘移除If快照"
EsxHostAdvSettings.Config.HostAgent.plugins.vmsvc.blockDiskRemoveIfSnapshot.summary="A flag that 块s all 虚拟磁盘 移除 operations on VMs that have 快照s."
EsxHostAdvSettings.Config.HostAgent.plugins.vmsvc.blockSnapshotRemoveIfDiskShared.label="plugins.vmsvc.块快照移除If磁盘份额d"
EsxHostAdvSettings.Config.HostAgent.plugins.vmsvc.blockSnapshotRemoveIfDiskShared.summary="A flag that 块s deletion of a 快照 if any 快照 磁盘 is in a 份额d 状态."
EsxHostAdvSettings.Config.HostAgent.plugins.vmsvc.allowForensicSnapshots.label="plugins.vmsvc.allowForensic快照s"
EsxHostAdvSettings.Config.HostAgent.plugins.vmsvc.allowForensicSnapshots.summary="A flag that allows 快照s to be taken that may not be restorable."
EsxHostAdvSettings.Config.HostAgent.plugins.vmsvc.enforceMaxRegisteredVms.label="限制 the number of 注册 虚拟机s"
EsxHostAdvSettings.Config.HostAgent.plugins.vmsvc.enforceMaxRegisteredVms.summary="启用s enforcing the 限制ation 在 number of 注册 虚拟机s 在 inventory."
EsxHostAdvSettings.Config.HostAgent.plugins.vmsvc.productLockerWatchInterval.label="plugins.vmsvc.product锁定erWatch间隔秒"
EsxHostAdvSettings.Config.HostAgent.plugins.vmsvc.productLockerWatchInterval.summary="间隔 介于 checks for whether the product 锁定er files are 更改, in 秒. 设置 to -1 to 禁用 checks."
EsxHostAdvSettings.Config.HostAgent.plugins.vmsvc.guestWatchdogTimeout.label="plugins.vmsvc.guestWatchdog超时"
EsxHostAdvSettings.Config.HostAgent.plugins.vmsvc.guestWatchdogTimeout.summary="Number of 秒 to wait 的 Guest OS to 关机."
EsxHostAdvSettings.Config.HostAgent.plugins.vmsvc.filterExtraConfigHotEdit.label="plugins.vmsvc.filterExtraConfigHotEdit"
EsxHostAdvSettings.Config.HostAgent.plugins.vmsvc.filterExtraConfigHotEdit.summary="Filter out extraConfig 键s being 修改 —— not on a pre-定义d list of allowed 键s when a 虚拟机 is 电源ed on."
EsxHostAdvSettings.Config.HostAgent.plugins.vmsvc.vsanVmRefreshRetryInterval.label="vmsvc.vsanVm刷新重试间隔"
EsxHostAdvSettings.Config.HostAgent.plugins.vmsvc.vsanVmRefreshRetryInterval.summary="Number of 秒 to wait for 重试ing vSAN VM 刷新, option 值 '0' means 正在禁用 重试 日志ic."
EsxHostAdvSettings.Config.HostAgent.ssl.keyStore.allowAny.label="ssl.键Store.allowAny"
EsxHostAdvSettings.Config.HostAgent.ssl.keyStore.allowAny.summary="Allow any 证书s to be 添加 到 主机 CA store. 禁用s CA checks."
EsxHostAdvSettings.Config.HostAgent.ssl.keyStore.allowSelfSigned.label="ssl.键Store.allowSelfSigned"
